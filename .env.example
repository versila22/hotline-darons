# ── Telegram ──────────────────────────────────────────────────────────────────
# Token du bot obtenu via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# ── Gemini / Google AI ────────────────────────────────────────────────────────
# Clé API Google AI Studio : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# ── Escalade ──────────────────────────────────────────────────────────────────
# Votre propre Telegram user ID (pour recevoir les alertes)
# Obtenez-le en envoyant /start à @userinfobot sur Telegram
ESCALATION_CHAT_ID=your_telegram_id_here

# ── Chemins (optionnels — valeurs par défaut dans les commentaires) ─────────
# KNOWLEDGE_DIR=/app/knowledge
# DB_PATH=/app/data/hotline_darons.db
